{
  "name": "nestjs-accesscontrol",
  "version": "1.0.0",
  "description": "Role & attribute-based access control for NestJS, built natively on accesscontrol v3 — fluent CRUD decorators, fail-closed guard, and attribute filtering.",
  "type": "module",
  "license": "MIT",
  "author": "Onur Yıldırım",
  "homepage": "https://github.com/onury/nestjs-accesscontrol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onury/nestjs-accesscontrol.git"
  },
  "bugs": {
    "url": "https://github.com/onury/nestjs-accesscontrol/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "nest",
    "accesscontrol",
    "access-control",
    "authorization",
    "rbac",
    "abac",
    "permissions",
    "roles",
    "guard"
  ],
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "accesscontrol": "^3",
    "reflect-metadata": "^0.2",
    "rxjs": "^7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-istanbul": "^2.1.8",
    "accesscontrol": "^3.0.0",
    "biome-config-oy": "^1.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
